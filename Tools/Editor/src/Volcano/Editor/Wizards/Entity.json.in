{
    "version": 1,
    "supportedProjectTypes": [ ],
    "id": "V.VolcanoEditor",
    "category": "VolcanoEngine",
    "trDescription": "Creates a VolcanoEngine project.",
    "trDisplayName": "VolcanoEngine Project",
    "trDisplayCategory": "VolcanoEngine",
    "iconText": "h/cpp/qml",
    "pages": [
        {
            "trDisplayName": "Basic",
            "trShortTitle": "Basic",
            "typeId": "Fields",
            "data": [
                {
                    "name": "Class",
                    "trDisplayName": "Class name:",
                    "mandatory": true,
                    "type": "LineEdit",
                    "data": {
                        "trPlaceholder": "Fully qualified name, including namespaces",
                        "validator": "(?:(?:[a-zA-Z_][a-zA-Z_0-9]*::)*[a-zA-Z_][a-zA-Z_0-9]*|)",
                        "completion": "namespaces"
                    }
                }
            ]
        }
    ]
}
