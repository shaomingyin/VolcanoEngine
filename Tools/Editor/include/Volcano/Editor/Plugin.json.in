{
    "Name": "VolcanoEditor",
    "Version": "13.0.1",
    "Category": "Game Engine",
    "Vendor": "Mingyin.Shao",
    "Copyright" : "(C) XXX",
    "Dependencies": [
        ${EDITOR_PLUGIN_DEPENDS_JSON}
    ],
    "Mimetypes" : [
        "<?xml version='1.0'?>",
        "<mime-info xmlns='http://www.freedesktop.org/standards/shared-mime-info'>",
        "    <mime-type type='${VOLCANO_EDITOR_MIME_PROJECT_FILE}'>",
        "        <sub-class-of type='application/json'/>",
        "        <comment>Volcano project file</comment>",
        "        <glob pattern='*.vpf'/>",
        "    </mime-type>",
        "    <mime-type type='${VOLCANO_EDITOR_MIME_SCENE_FILE}'>",
        "        <sub-class-of type='application/json'/>",
        "        <comment>Volcano scene file</comment>",
        "        <glob pattern='*.vsf'/>",
        "    </mime-type>",
        "</mime-info>"
    ]
}
