{
	"Id": "VolcanoEditor",
    "Name": "Volcano Editor",
    "Version": "${CMAKE_PROJECT_VERSION}",
	"Vendor": "Shaomy",
	"Dependencies": [
	],
	"Mimetypes" : [
	    "<?xml version='1.0'?>",
		"<mime-info xmlns='http://www.freedesktop.org/standards/shared-mime-info'>",
		"  <mime-type type='application/x-volcano-project'>",
		"    <sub-class-of type='application/json'/>",
		"    <comment>Volcano Project file</comment>",
		"    <glob pattern='Manifest.vpf'/>",
		"  </mime-type>",
		"</mime-info>"
	]
}
